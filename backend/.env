PORT=8080
TELEGRAM_BOT_USERNAME=voucherly_auth_bot
TELEGRAM_BOT_TOKEN=PUT_NEW_TELEGRAM_BOT_TOKEN_HERE

# Option A: JSON string service account (recommended for cloud env)
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}

# Option B: local file path (recommended for local dev)
# GOOGLE_APPLICATION_CREDENTIALS=/absolute/path/to/service-account.json

TELEGRAM_AUTH_MAX_AGE_SECONDS=86400
