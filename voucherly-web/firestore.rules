rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwnerByData(data) {
      return isSignedIn()
        && (
          data.userId == request.auth.uid
          || data.userID == request.auth.uid
          || data.receiverUid == request.auth.uid
          || data.claimedBy == request.auth.uid
        );
    }

    match /orders/{orderId} {
      allow read: if isOwnerByData(resource.data);

      allow create: if isSignedIn()
        && (
          request.resource.data.userId == request.auth.uid
          || request.resource.data.userID == request.auth.uid
        );

      allow update, delete: if isOwnerByData(resource.data);
    }

    // User private data and subcollections (vouchers, devices, etc.)
    match /users/{uid} {
      allow read, write: if isSignedIn() && request.auth.uid == uid;

      match /{document=**} {
        allow read, write: if isSignedIn() && request.auth.uid == uid;
      }
    }

    // Keep everything else denied by default.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
